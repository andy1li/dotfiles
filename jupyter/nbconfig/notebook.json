{
  "Notebook": {
    "Header": true,
    "Toolbar": true
  },
  "keys": {
    "command": {
      "bind": {
        "shift-r": "jupyter-notebook:restart-kernel-and-run-all-cells",
        "shift-cmd-up": "jupyter-notebook:move-cell-up",
        "shift-cmd-down": "jupyter-notebook:move-cell-down",
        "shift-cmd-j": "jupyter-notebook:move-cell-down",
        "shift-cmd-k": "jupyter-notebook:move-cell-up"
      }
    }
  },
  "Cell": {
    "cm_config": {
      "lineNumbers": false
    }
  }
}